{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "hono": "jsr:@hono/hono@^4.12.10",
    "vite": "npm:vite@^8.0.3"
  },
  "tasks": {
    "start": "deno run --watch --allow-net main.tsx",
    "build": " deno run -A npm:vite build"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto"
}
