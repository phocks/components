{
  "imports": {
    "@elenajs/bundler": "npm:@elenajs/bundler@^1.0.0-rc.10",
    "@elenajs/core": "npm:@elenajs/core@^1.0.0-rc.10",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "hono": "jsr:@hono/hono@^4.12.10"
  },
  "tasks": {
    "start": "deno run --watch --allow-all main.js"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto",
  "allowScripts": ["npm:rs-module-lexer@2.8.0"]
}
